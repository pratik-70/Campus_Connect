# Server
PORT=4000
FRONTEND_ORIGIN=http://127.0.0.1:5500

# Security (required)
JWT_SECRET=replace-with-a-long-random-secret
OTP_PEPPER=replace-with-another-random-secret

# OTP behavior
OTP_EXPIRY_MINUTES=10
JWT_SIGNUP_PROOF_EXPIRY=15m

# Optional email provider (Resend)
# If not provided, OTP codes are logged to backend console in local development.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_AUDIENCE_NAME=Campus Connect
